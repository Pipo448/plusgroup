  creator     User?         @relation("SabotayPaymentCreatedBy", fields: [createdBy], references: [id], onUpdate: NoAction)
  member      SabotayMember @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan        SabotayPlan   @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([planId], map: "sabotay_payments_plan_idx")
  @@index([memberId], map: "sabotay_payments_member_idx")
