  firstName      String            @map("first_name") @db.VarChar(100)
  lastName       String            @map("last_name") @db.VarChar(100)
  address        String?
  nifOrCin       String?           @map("nif_or_cin") @db.VarChar(50)
  phone          String?           @db.VarChar(50)
  openingAmount  Decimal           @default(0) @map("opening_amount") @db.Decimal(14, 2)
  kaneFee        Decimal           @default(0) @map("kane_fee") @db.Decimal(14, 2)
  lockedAmount   Decimal           @default(0) @map("locked_amount") @db.Decimal(14, 2)
  balance        Decimal           @default(0) @db.Decimal(14, 2)
