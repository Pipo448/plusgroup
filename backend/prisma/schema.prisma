model KaneTransaction {
  id            String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId      String              @map("tenant_id")
  accountId     String              @map("account_id")
  type          KaneTransactionType
  amount        Decimal             @db.Decimal(14, 2)
  balanceBefore Decimal             @map("balance_before") @db.Decimal(14, 2)
  balanceAfter  Decimal             @map("balance_after") @db.Decimal(14, 2)
  method        PaymentMethod       @default(cash)
  reference     String?             @db.VarChar(200)
  notes         String?
  createdBy     String?             @map("created_by")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  account       KaneEpay            @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kane_transactions_account_fk")
  creator       User?               @relation("KaneTxCreatedBy", fields: [createdBy], references: [id], onUpdate: NoAction, map: "kane_transactions_creator_fk")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kane_transactions_tenant_fk")

  @@index([accountId], map: "kane_transactions_account_idx")
  @@index([createdAt], map: "kane_transactions_created_idx")
  @@index([tenantId], map: "kane_transactions_tenant_idx")
  @@map("kane_transactions")
}

model SabotayPlan {
  id              String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId        String           @map("tenant_id")
  branchId        String?          @map("branch_id")
  name            String           @db.VarChar(200)
  frequency       String           @db.VarChar(20)
  amount          Decimal          @db.Decimal(14, 2)
  maxMembers      Int              @map("max_members")
  fee             Decimal          @default(0) @db.Decimal(14, 2)
  startDate       DateTime         @map("start_date") @db.Timestamptz(6)
  status          String           @default("active") @db.VarChar(20)
  notes           String?
  createdBy       String?          @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  feePerMember    Decimal          @default(0) @map("fee_per_member") @db.Decimal(14, 2)
  penalty         Decimal          @default(0) @db.Decimal(14, 2)
  interval        Int              @default(1)
  regleman        String?
  dueTime         String           @default("08:00") @map("due_time") @db.VarChar(5)
  warningDelayDays Int             @default(3) @map("warningDelayDays")
  members         SabotayMember[]
  payments        SabotayPayment[]
  branch          Branch?          @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  creator         User?            @relation("SabotayPlanCreatedBy", fields: [createdBy], references: [id], onUpdate: NoAction)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "sabotay_plans_tenant_idx")
  @@index([branchId], map: "sabotay_plans_branch_idx")
  @@index([tenantId, status], map: "sabotay_plans_status_idx")
  @@map("sabotay_plans")
}

model SabotayMember {
  id          String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  planId      String           @map("plan_id")
  name        String           @db.VarChar(200)
  phone       String?          @db.VarChar(50)
  position    Int
  dueDate     DateTime?        @map("due_date") @db.Date
  collectDate DateTime?        @map("collect_date") @db.Date
  notes       String?
  isActive    Boolean          @default(true) @map("is_active")
  createdBy   String?          @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  hasWon      Boolean          @default(false) @map("has_won")
  isOwnerSlot Boolean          @default(false) @map("is_owner_slot")
  fines       Json             @default("{}")
  status      String           @default("active")
  creator     User?            @relation("SabotayMemberCreatedBy", fields: [createdBy], references: [id], onUpdate: NoAction)
  plan        SabotayPlan      @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments    SabotayPayment[]

  @@unique([planId, position], map: "sabotay_members_plan_position_key")
  @@index([planId], map: "sabotay_members_plan_idx")
  @@index([planId, isActive], map: "sabotay_members_active_idx")
  @@map("sabotay_members")
}

model SabotayPayment {
  id          String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  planId      String        @map("plan_id")
  memberId    String        @map("member_id")
  amount      Decimal       @db.Decimal(14, 2)
  paidDate    DateTime?     @map("paid_date") @db.Date
