model RoomType {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  name                  String   @db.VarChar(100)
  description           String?
  priceHtg              Decimal  @map("price_htg") @db.Decimal(12, 2)
  priceUsd              Decimal  @default(0) @map("price_usd") @db.Decimal(12, 2)
  maxAdults             Int      @default(2) @map("max_adults")
  maxChildren           Int      @default(1) @map("max_children")
  amenities             Json     @default("[]")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  momentPriceHtg        Decimal? @map("moment_price_htg") @db.Decimal(12, 2)
  momentPricePerHourHtg Decimal? @map("moment_price_per_hour_htg") @db.Decimal(12, 2)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms                 Room[]

  @@index([tenantId])
  @@map("room_types")
}

model Room {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  branchId     String?       @map("branch_id")
  roomTypeId   String        @map("room_type_id")
  number       String        @db.VarChar(20)
  floor        Int           @default(1)
  description  String?
  status       RoomStatus    @default(available)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  reservations Reservation[]
  branch       Branch?       @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  roomType     RoomType      @relation(fields: [roomTypeId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, number])
  @@index([tenantId])
  @@index([branchId])
  @@map("rooms")
}

model Reservation {
  id                    String            @id @default(uuid())
  tenantId              String            @map("tenant_id")
  branchId              String?           @map("branch_id")
  reservationNumber     String            @map("reservation_number") @db.VarChar(50)
  roomId                String            @map("room_id")
  clientId              String?           @map("client_id")
  clientSnapshot        Json              @map("client_snapshot")
  adults                Int               @default(1)
  children              Int               @default(0)
  checkIn               DateTime          @map("check_in") @db.Timestamptz(6)
  checkOut              DateTime          @map("check_out") @db.Timestamptz(6)
  nights                Int
  pricePerNight         Decimal           @map("price_per_night") @db.Decimal(12, 2)
  roomTotalHtg          Decimal           @default(0) @map("room_total_htg") @db.Decimal(14, 2)
  servicesTotalHtg      Decimal           @default(0) @map("services_total_htg") @db.Decimal(14, 2)
  totalHtg              Decimal           @default(0) @map("total_htg") @db.Decimal(14, 2)
  amountPaidHtg         Decimal           @default(0) @map("amount_paid_htg") @db.Decimal(14, 2)
  balanceDueHtg         Decimal           @default(0) @map("balance_due_htg") @db.Decimal(14, 2)
  depositHtg            Decimal           @default(0) @map("deposit_htg") @db.Decimal(14, 2)
  status                ReservationStatus @default(pending)
  source                String?           @db.VarChar(50)
  notes                 String?
  invoiceId             String?           @unique @map("invoice_id")
  createdBy             String?           @map("created_by")
  checkedInAt           DateTime?         @map("checked_in_at") @db.Timestamptz(6)
  checkedOutAt          DateTime?         @map("checked_out_at") @db.Timestamptz(6)
  cancelledAt           DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancelReason          String?           @map("cancel_reason")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  type                  String            @default("nuit") @db.VarChar(10)
  momentDurationMinutes Int?              @map("moment_duration_minutes")
  momentStartTime       DateTime?         @map("moment_start_time") @db.Timestamptz(6)
  momentEndTime         DateTime?         @map("moment_end_time") @db.Timestamptz(6)
  momentExtraHours      Int?              @map("moment_extra_hours")
  momentExtraChargeHtg  Decimal?          @map("moment_extra_charge_htg") @db.Decimal(12, 2)
  payments              HotelPayment[]
  services              HotelService[]
  branch                Branch?           @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  client                Client?           @relation(fields: [clientId], references: [id])
  creator               User?             @relation("ReservationCreatedBy", fields: [createdBy], references: [id])
  invoice               Invoice?          @relation(fields: [invoiceId], references: [id])
  room                  Room              @relation(fields: [roomId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reservationNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([roomId])
  @@map("reservations")
}

model HotelService {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  reservationId String      @map("reservation_id")
  productId     String?     @map("product_id")
  type          ServiceType @default(other)
  description   String      @db.VarChar(200)
  quantity      Decimal     @default(1) @db.Decimal(12, 3)
  unitPriceHtg  Decimal     @map("unit_price_htg") @db.Decimal(12, 2)
  totalHtg      Decimal     @map("total_htg") @db.Decimal(14, 2)
  notes         String?
  createdBy     String?     @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  creator       User?       @relation("HotelServiceCreatedBy", fields: [createdBy], references: [id])
  product       Product?    @relation(fields: [productId], references: [id])
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([tenantId])
  @@map("hotel_services")
}

model HotelPayment {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  reservationId String        @map("reservation_id")
  amountHtg     Decimal       @map("amount_htg") @db.Decimal(14, 2)
  method        PaymentMethod @default(cash)
  type          String        @default("payment") @db.VarChar(20)
  reference     String?       @db.VarChar(200)
  notes         String?
  createdBy     String?       @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  creator       User?         @relation("HotelPaymentCreatedBy", fields: [createdBy], references: [id])
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([tenantId])
  @@map("hotel_payments")
}

model admin_audit_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String?   @db.Uuid
  action       String    @db.VarChar(100)
  actor        String?   @default("Super Admin") @db.VarChar(200)
  target_email String?   @db.VarChar(200)
  target_name  String?   @db.VarChar(200)
  details      Json?     @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([tenant_id, created_at(sort: Desc)], map: "idx_audit_tenant")
