generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model activity_logs {
  id          String   @id
  tenant_id   String?
  user_id     String?
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   String?
  old_data    Json?
  new_data    Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())
  tenants     tenants? @relation(fields: [tenant_id], references: [id])
  users       users?   @relation(fields: [user_id], references: [id])
}

model admin_audit_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String?   @db.Uuid
  action       String    @db.VarChar(100)
  actor        String?   @default("Super Admin") @db.VarChar(200)
  target_email String?   @db.VarChar(200)
  target_name  String?   @db.VarChar(200)
  details      Json?     @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([tenant_id, created_at(sort: Desc)], map: "idx_audit_tenant")
}

model branch_users {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  branch_id  String
  user_id    String
  role       String   @default("cashier")
  is_admin   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  branches   branches @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([branch_id, user_id])
  @@index([branch_id])
  @@index([user_id])
}

model branches {
  id                 String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenant_id          String
  name               String               @db.VarChar(200)
  slug               String               @db.VarChar(100)
  description        String?
  address            String?
  phone              String?              @db.VarChar(50)
  email              String?              @db.VarChar(150)
  is_active          Boolean              @default(false)
  unlocked_at        DateTime?            @db.Timestamptz(6)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  branch_users       branch_users[]
  tenants            tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clients            clients[]
  invoices           invoices[]
  kane_epay_accounts kane_epay_accounts[]
  product_categories product_categories[]
  products           products[]
  quotes             quotes[]
  reservations       reservations[]
  rooms              rooms[]
  sabotay_plans      sabotay_plans[]
  stock_movements    stock_movements[]

  @@unique([tenant_id, slug])
  @@index([tenant_id])
}

model clients {
  id                 String          @id
  tenant_id          String
  client_type        String          @default("individual") @db.VarChar(20)
  name               String          @db.VarChar(200)
  company_name       String?         @db.VarChar(200)
  email              String?         @db.VarChar(150)
  phone              String?         @db.VarChar(50)
  phone2             String?         @db.VarChar(50)
  address            String?
  city               String?         @db.VarChar(100)
  nif                String?         @db.VarChar(50)
  credit_limit       Decimal         @default(0) @db.Decimal(12, 2)
  balance            Decimal         @default(0) @db.Decimal(12, 2)
  preferred_currency DefaultCurrency @default(HTG)
  notes              String?
  is_active          Boolean         @default(true)
  created_by         String?
  created_at         DateTime        @default(now())
  updated_at         DateTime
  branch_id          String?
  branches           branches?       @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users              users?          @relation(fields: [created_by], references: [id])
  tenants            tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoices           invoices[]
  quotes             quotes[]
  reservations       reservations[]

  @@index([branch_id])
}

model document_sequences {
  id            String   @id
  tenant_id     String
  document_type String   @db.VarChar(20)
  prefix        String   @default("DOC") @db.VarChar(20)
  last_number   Int      @default(0)
  year_reset    Boolean  @default(true)
  current_year  Int      @default(2024)
  created_at    DateTime @default(now())
  updated_at    DateTime
  tenants       tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, document_type])
}

model hotel_payments {
  id             String        @id
  tenant_id      String
  reservation_id String
  amount_htg     Decimal       @db.Decimal(14, 2)
  method         PaymentMethod @default(cash)
  type           String        @default("payment") @db.VarChar(20)
  reference      String?       @db.VarChar(200)
  notes          String?
  created_by     String?
  created_at     DateTime      @default(now())
  users          users?        @relation(fields: [created_by], references: [id])
  reservations   reservations  @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  tenants        tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([reservation_id])
  @@index([tenant_id])
}

model hotel_services {
  id             String       @id
  tenant_id      String
  reservation_id String
  product_id     String?
  type           ServiceType  @default(other)
  description    String       @db.VarChar(200)
  quantity       Decimal      @default(1) @db.Decimal(12, 3)
  unit_price_htg Decimal      @db.Decimal(12, 2)
  total_htg      Decimal      @db.Decimal(14, 2)
  notes          String?
  created_by     String?
  created_at     DateTime     @default(now())
  users          users?       @relation(fields: [created_by], references: [id])
  products       products?    @relation(fields: [product_id], references: [id])
  reservations   reservations @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  tenants        tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([reservation_id])
  @@index([tenant_id])
}

model invoice_items {
  id               String    @id
  tenant_id        String
  invoice_id       String
  product_id       String?
  product_snapshot Json
  quantity         Decimal   @db.Decimal(12, 3)
  unit_price_htg   Decimal   @db.Decimal(12, 2)
  unit_price_usd   Decimal   @db.Decimal(12, 2)
  discount_pct     Decimal   @default(0) @db.Decimal(5, 2)
  total_htg        Decimal   @db.Decimal(14, 2)
  total_usd        Decimal   @db.Decimal(14, 2)
  stock_before     Decimal?  @db.Decimal(12, 3)
  stock_after      Decimal?  @db.Decimal(12, 3)
  sort_order       Int       @default(0)
  notes            String?
  created_at       DateTime  @default(now())
  invoices         invoices  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  products         products? @relation(fields: [product_id], references: [id])
  tenants          tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model invoices {
  id                                 String          @id
  tenant_id                          String
  invoice_number                     String          @db.VarChar(50)
  quote_id                           String?         @unique
  client_id                          String?
  client_snapshot                    Json
  currency                           DefaultCurrency @default(HTG)
  exchange_rate                      Decimal         @db.Decimal(10, 4)
  subtotal_htg                       Decimal         @default(0) @db.Decimal(14, 2)
  subtotal_usd                       Decimal         @default(0) @db.Decimal(14, 2)
  discount_type                      String          @default("amount") @db.VarChar(10)
  discount_value                     Decimal         @default(0) @db.Decimal(10, 2)
  discount_htg                       Decimal         @default(0) @db.Decimal(14, 2)
  discount_usd                       Decimal         @default(0) @db.Decimal(14, 2)
  tax_rate                           Decimal         @default(0) @db.Decimal(5, 2)
  tax_htg                            Decimal         @default(0) @db.Decimal(14, 2)
  tax_usd                            Decimal         @default(0) @db.Decimal(14, 2)
  total_htg                          Decimal         @default(0) @db.Decimal(14, 2)
  total_usd                          Decimal         @default(0) @db.Decimal(14, 2)
  amount_paid_htg                    Decimal         @default(0) @db.Decimal(14, 2)
  amount_paid_usd                    Decimal         @default(0) @db.Decimal(14, 2)
  balance_due_htg                    Decimal         @default(0) @db.Decimal(14, 2)
  balance_due_usd                    Decimal         @default(0) @db.Decimal(14, 2)
  status                             InvoiceStatus   @default(unpaid)
  issue_date                         DateTime        @default(now()) @db.Timestamptz(6)
  due_date                           DateTime?       @db.Timestamptz(6)
  notes                              String?
  terms                              String?
  stock_decremented                  Boolean         @default(false)
  created_by                         String?
  cancelled_by                       String?
  cancelled_at                       DateTime?
  cancel_reason                      String?
  created_at                         DateTime        @default(now())
  updated_at                         DateTime
  branch_id                          String?
  invoice_items                      invoice_items[]
  branches                           branches?       @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users_invoices_cancelled_byTousers users?          @relation("invoices_cancelled_byTousers", fields: [cancelled_by], references: [id])
  clients                            clients?        @relation(fields: [client_id], references: [id])
  users_invoices_created_byTousers   users?          @relation("invoices_created_byTousers", fields: [created_by], references: [id])
  quotes                             quotes?         @relation(fields: [quote_id], references: [id], onDelete: Restrict)
  tenants                            tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  payments                           payments[]
  reservations                       reservations?

  @@unique([tenant_id, invoice_number])
  @@index([branch_id])
}

model kane_epay_accounts {
  id                String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenant_id         String
  branch_id         String?
  account_number    String              @db.VarChar(30)
  first_name        String              @db.VarChar(100)
  last_name         String              @db.VarChar(100)
  address           String?
  nif_or_cin        String?             @db.VarChar(50)
  phone             String?             @db.VarChar(50)
  opening_amount    Decimal             @default(0) @db.Decimal(14, 2)
  kane_fee          Decimal             @default(0) @db.Decimal(14, 2)
  locked_amount     Decimal             @default(0) @db.Decimal(14, 2)
  balance           Decimal             @default(0) @db.Decimal(14, 2)
  is_active         Boolean             @default(true)
  created_by        String?
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  family_relation   String?             @db.VarChar(100)
  family_name       String?             @db.VarChar(100)
  photo_url         String?
  id_photo_url      String?
  branches          branches?           @relation(fields: [branch_id], references: [id], onUpdate: NoAction, map: "kane_epay_accounts_branch_fk")
  users             users?              @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "kane_epay_accounts_creator_fk")
  tenants           tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kane_epay_accounts_tenant_fk")
  kane_transactions kane_transactions[]

  @@unique([tenant_id, account_number], map: "kane_epay_accounts_tenant_account_key")
  @@index([tenant_id, is_active], map: "kane_epay_accounts_active_idx")
  @@index([branch_id], map: "kane_epay_accounts_branch_idx")
  @@index([tenant_id], map: "kane_epay_accounts_tenant_idx")
}

model kane_transactions {
  id                 String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenant_id          String
  account_id         String
  type               KaneTransactionType
  amount             Decimal             @db.Decimal(14, 2)
  balance_before     Decimal             @db.Decimal(14, 2)
  balance_after      Decimal             @db.Decimal(14, 2)
  method             PaymentMethod       @default(cash)
  reference          String?             @db.VarChar(200)
  notes              String?
  created_by         String?
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  kane_epay_accounts kane_epay_accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kane_transactions_account_fk")
  users              users?              @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "kane_transactions_creator_fk")
  tenants            tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kane_transactions_tenant_fk")

  @@index([account_id], map: "kane_transactions_account_idx")
  @@index([created_at], map: "kane_transactions_created_idx")
  @@index([tenant_id], map: "kane_transactions_tenant_idx")
}

model notifications {
  id          String    @id
  tenant_id   String
  user_id     String?
  type        String    @db.VarChar(50)
  title_ht    String?
  title_fr    String?
  title_en    String?
  message_ht  String?
  message_fr  String?
  message_en  String?
  entity_type String?   @db.VarChar(50)
  entity_id   String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  created_at  DateTime  @default(now())
  tenants     tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model payments {
  id            String          @id
  tenant_id     String
  invoice_id    String
  amount_htg    Decimal         @default(0) @db.Decimal(14, 2)
  amount_usd    Decimal         @default(0) @db.Decimal(14, 2)
  currency      DefaultCurrency @default(HTG)
  exchange_rate Decimal?        @db.Decimal(10, 4)
  method        PaymentMethod   @default(cash)
  reference     String?         @db.VarChar(200)
  payment_date  DateTime        @default(now()) @db.Timestamptz(6)
  notes         String?
  created_by    String?
  created_at    DateTime        @default(now())
  users         users?          @relation(fields: [created_by], references: [id])
  invoices      invoices        @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model product_categories {
  id          String     @id
  tenant_id   String
  name        String     @db.VarChar(100)
  name_fr     String?    @db.VarChar(100)
  name_en     String?    @db.VarChar(100)
  description String?
  color       String?    @db.VarChar(7)
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime
  branch_id   String?
  branches    branches?  @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  tenants     tenants    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  products    products[]

  @@unique([tenant_id, branch_id, name])
  @@unique([tenant_id, name])
}

model products {
  id                 String              @id
  tenant_id          String
  category_id        String?
  code               String?             @db.VarChar(100)
  name               String              @db.VarChar(200)
  name_fr            String?             @db.VarChar(200)
  name_en            String?             @db.VarChar(200)
  description        String?
  unit               String              @default("unité") @db.VarChar(50)
  price_htg          Decimal             @default(0) @db.Decimal(12, 2)
  price_usd          Decimal             @default(0) @db.Decimal(12, 2)
  cost_price_htg     Decimal             @default(0) @db.Decimal(12, 2)
  quantity           Decimal             @default(0) @db.Decimal(12, 3)
  alert_threshold    Decimal             @default(5) @db.Decimal(12, 3)
  image_url          String?
  is_active          Boolean             @default(true)
  is_service         Boolean             @default(false)
  created_by         String?
  created_at         DateTime            @default(now())
  updated_at         DateTime
  branch_id          String?
  hotel_services     hotel_services[]
  invoice_items      invoice_items[]
  branches           branches?           @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  product_categories product_categories? @relation(fields: [category_id], references: [id])
  users              users?              @relation(fields: [created_by], references: [id])
  tenants            tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  quote_items        quote_items[]
  stock_movements    stock_movements[]

  @@unique([tenant_id, code])
  @@index([branch_id])
}

model quote_items {
  id               String    @id
  tenant_id        String
  quote_id         String
  product_id       String?
  product_snapshot Json
  quantity         Decimal   @db.Decimal(12, 3)
  unit_price_htg   Decimal   @db.Decimal(12, 2)
  unit_price_usd   Decimal   @db.Decimal(12, 2)
  discount_pct     Decimal   @default(0) @db.Decimal(5, 2)
  total_htg        Decimal   @db.Decimal(14, 2)
  total_usd        Decimal   @db.Decimal(14, 2)
  sort_order       Int       @default(0)
  notes            String?
  created_at       DateTime  @default(now())
  products         products? @relation(fields: [product_id], references: [id])
  quotes           quotes    @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  tenants          tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model quotes {
  id                      String          @id
  tenant_id               String
  quote_number            String          @db.VarChar(50)
  client_id               String?
  client_snapshot         Json
  currency                DefaultCurrency @default(HTG)
  exchange_rate           Decimal         @db.Decimal(10, 4)
  subtotal_htg            Decimal         @default(0) @db.Decimal(14, 2)
  subtotal_usd            Decimal         @default(0) @db.Decimal(14, 2)
  discount_type           String          @default("amount") @db.VarChar(10)
  discount_value          Decimal         @default(0) @db.Decimal(10, 2)
  discount_htg            Decimal         @default(0) @db.Decimal(14, 2)
  discount_usd            Decimal         @default(0) @db.Decimal(14, 2)
  tax_rate                Decimal         @default(0) @db.Decimal(5, 2)
  tax_htg                 Decimal         @default(0) @db.Decimal(14, 2)
  tax_usd                 Decimal         @default(0) @db.Decimal(14, 2)
  total_htg               Decimal         @default(0) @db.Decimal(14, 2)
  total_usd               Decimal         @default(0) @db.Decimal(14, 2)
  status                  QuoteStatus     @default(draft)
  issue_date              DateTime        @default(now()) @db.Timestamptz(6)
  expiry_date             DateTime?       @db.Timestamptz(6)
  notes                   String?
  terms                   String?
  created_by              String?
  converted_to_invoice_id String?
  converted_at            DateTime?
  created_at              DateTime        @default(now())
  updated_at              DateTime
  branch_id               String?
  invoices                invoices?
  quote_items             quote_items[]
  branches                branches?       @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  clients                 clients?        @relation(fields: [client_id], references: [id])
  users                   users?          @relation(fields: [created_by], references: [id])
  tenants                 tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, quote_number])
  @@index([branch_id])
}

model reservations {
  id                      String            @id
  tenant_id               String
  branch_id               String?
  reservation_number      String            @db.VarChar(50)
  room_id                 String
  client_id               String?
  client_snapshot         Json
  adults                  Int               @default(1)
  children                Int               @default(0)
  check_in                DateTime          @db.Timestamptz(6)
  check_out               DateTime          @db.Timestamptz(6)
  nights                  Int
  price_per_night         Decimal           @db.Decimal(12, 2)
  room_total_htg          Decimal           @default(0) @db.Decimal(14, 2)
  services_total_htg      Decimal           @default(0) @db.Decimal(14, 2)
  total_htg               Decimal           @default(0) @db.Decimal(14, 2)
  amount_paid_htg         Decimal           @default(0) @db.Decimal(14, 2)
  balance_due_htg         Decimal           @default(0) @db.Decimal(14, 2)
  deposit_htg             Decimal           @default(0) @db.Decimal(14, 2)
  status                  ReservationStatus @default(pending)
  source                  String?           @db.VarChar(50)
  notes                   String?
  invoice_id              String?           @unique
  created_by              String?
  checked_in_at           DateTime?         @db.Timestamptz(6)
  checked_out_at          DateTime?         @db.Timestamptz(6)
  cancelled_at            DateTime?         @db.Timestamptz(6)
  cancel_reason           String?
  created_at              DateTime          @default(now())
  updated_at              DateTime
  type                    String            @default("nuit") @db.VarChar(10)
  moment_duration_minutes Int?
  moment_start_time       DateTime?         @db.Timestamptz(6)
  moment_end_time         DateTime?         @db.Timestamptz(6)
  moment_extra_hours      Int?
  moment_extra_charge_htg Decimal?          @db.Decimal(12, 2)
  hotel_payments          hotel_payments[]
  hotel_services          hotel_services[]
  branches                branches?         @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  clients                 clients?          @relation(fields: [client_id], references: [id])
  users                   users?            @relation(fields: [created_by], references: [id])
  invoices                invoices?         @relation(fields: [invoice_id], references: [id])
  rooms                   rooms             @relation(fields: [room_id], references: [id])
  tenants                 tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, reservation_number])
  @@index([branch_id])
  @@index([room_id])
  @@index([tenant_id])
}

model room_types {
  id                        String   @id
  tenant_id                 String
  name                      String   @db.VarChar(100)
  description               String?
  price_htg                 Decimal  @db.Decimal(12, 2)
  price_usd                 Decimal  @default(0) @db.Decimal(12, 2)
  max_adults                Int      @default(2)
  max_children              Int      @default(1)
  amenities                 Json     @default("[]")
  is_active                 Boolean  @default(true)
  created_at                DateTime @default(now())
  updated_at                DateTime
  moment_price_htg          Decimal? @db.Decimal(12, 2)
  moment_price_per_hour_htg Decimal? @db.Decimal(12, 2)
  tenants                   tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rooms                     rooms[]

  @@index([tenant_id])
}

model rooms {
  id           String         @id
  tenant_id    String
  branch_id    String?
  room_type_id String
  number       String         @db.VarChar(20)
  floor        Int            @default(1)
  description  String?
  status       RoomStatus     @default(available)
  is_active    Boolean        @default(true)
  created_at   DateTime       @default(now())
  updated_at   DateTime
  reservations reservations[]
  branches     branches?      @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  room_types   room_types     @relation(fields: [room_type_id], references: [id])
  tenants      tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, branch_id, number])
  @@index([branch_id])
  @@index([tenant_id])
}

model sabotay_members {
  id               String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  plan_id          String
  name             String             @db.VarChar(200)
  phone            String?            @db.VarChar(50)
  position         Int
  due_date         DateTime?          @db.Date
  collect_date     DateTime?          @db.Date
  notes            String?
  is_active        Boolean            @default(true)
  created_by       String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  has_won          Boolean            @default(false)
  is_owner_slot    Boolean            @default(false)
  fines            Json               @default("{}")
  status           String             @default("active") @db.VarChar(20)
  users            users?             @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  sabotay_plans    sabotay_plans      @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sabotay_payments sabotay_payments[]

  @@unique([plan_id, position], map: "sabotay_members_plan_position_key")
  @@index([plan_id, is_active], map: "sabotay_members_active_idx")
  @@index([plan_id], map: "sabotay_members_plan_idx")
}

model sabotay_payments {
  id              String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  plan_id         String
  member_id       String
  amount          Decimal         @db.Decimal(14, 2)
  due_date        DateTime        @db.Date
  paid_at         DateTime        @db.Timestamptz(6)
  method          String          @default("cash") @db.VarChar(20)
  notes           String?
  created_by      String?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  timing          String?         @db.VarChar(10)
  fine_amt        Decimal         @default(0) @db.Decimal(14, 2)
  users           users?          @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  sabotay_members sabotay_members @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sabotay_plans   sabotay_plans   @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([plan_id, member_id, due_date], map: "sabotay_payments_unique_per_date")
  @@index([due_date], map: "sabotay_payments_date_idx")
  @@index([member_id], map: "sabotay_payments_member_idx")
  @@index([plan_id], map: "sabotay_payments_plan_idx")
}

model sabotay_plans {
  id               String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenant_id        String
  branch_id        String?
  name             String             @db.VarChar(200)
  frequency        String             @db.VarChar(20)
  amount           Decimal            @db.Decimal(14, 2)
  max_members      Int
  fee              Decimal            @default(0) @db.Decimal(14, 2)
  start_date       DateTime           @db.Timestamptz(6)
  status           String             @default("active") @db.VarChar(20)
  notes            String?
  created_by       String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  fee_per_member   Decimal            @default(0) @db.Decimal(14, 2)
  penalty          Decimal            @default(0) @db.Decimal(14, 2)
  interval         Int                @default(1)
  regleman         String?
  due_time         String             @default("08:00") @db.VarChar(5)
  warningDelayDays Int                @default(3)
  sabotay_members  sabotay_members[]
  sabotay_payments sabotay_payments[]
  branches         branches?          @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users            users?             @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  tenants          tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([branch_id], map: "sabotay_plans_branch_idx")
  @@index([tenant_id, status], map: "sabotay_plans_status_idx")
  @@index([tenant_id], map: "sabotay_plans_tenant_idx")
}

model sol_member_accounts {
  id                   String                 @id
  username             String                 @unique
  password_hash        String
  tenant_id            String
  member_id            String
  member_name          String
  member_phone         String                 @default("")
  member_position      Int
  plan_id              String
  plan_name            String
  plan_amount          Float
  plan_fee             Float                  @default(0)
  plan_frequency       String
  plan_max_members     Int
  plan_created_at      String
  plan_due_time        String                 @default("08:00")
  payments             Json                   @default("{}")
  payment_timings      Json                   @default("{}")
  created_at           DateTime               @default(now())
  updated_at           DateTime
  plan_interval        Int                    @default(1)
  plan_fee_per_member  Float                  @default(0)
  plan_penalty         Float                  @default(0)
  plan_regleman        String?
  is_owner_slot        Boolean                @default(false)
  has_won              Boolean                @default(false)
  fines                Json                   @default("{}")
  plain_password       String?
  sol_member_positions sol_member_positions[]

  @@index([member_id], map: "sol_member_accounts_member_idx")
  @@index([tenant_id], map: "sol_member_accounts_tenant_idx")
}

model sol_member_positions {
  id                  String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  accountId           String
  tenantId            String
  memberId            String
  memberPosition      Int
  planId              String
  planName            String?
  planAmount          Decimal?            @default(0) @db.Decimal(12, 2)
  planFee             Decimal?            @default(0) @db.Decimal(12, 2)
  planFrequency       String?
  planMaxMembers      Int?                @default(0)
  planStartDate       String?
  planDueTime         String?             @default("08:00")
  planInterval        Int?                @default(1)
  planFeePerMember    Decimal?            @default(0) @db.Decimal(12, 2)
  planPenalty         Decimal?            @default(0) @db.Decimal(12, 2)
  planRegleman        String?
  isOwnerSlot         Boolean?            @default(false)
  hasWon              Boolean?            @default(false)
  preferredDate       String?
  payments            Json?               @default("{}")
  paymentTimings      Json?               @default("{}")
  fines               Json?               @default("{}")
  status              String?             @default("active") @db.VarChar(20)
  createdAt           DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?           @default(now()) @db.Timestamp(6)
  sol_member_accounts sol_member_accounts @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model stock_movements {
  id              String            @id
  tenant_id       String
  product_id      String
  movement_type   StockMovementType
  reference_id    String?
  reference_type  String?           @db.VarChar(50)
  quantity_before Decimal           @db.Decimal(12, 3)
  quantity_change Decimal           @db.Decimal(12, 3)
  quantity_after  Decimal           @db.Decimal(12, 3)
  unit_cost_htg   Decimal?          @db.Decimal(12, 2)
  notes           String?
  created_by      String?
  created_at      DateTime          @default(now())
  branch_id       String?
  branches        branches?         @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users           users?            @relation(fields: [created_by], references: [id])
  products        products          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  tenants         tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model subscription_plans {
  id                   String                 @id
  name                 String                 @db.VarChar(100)
  name_fr              String?                @db.VarChar(100)
  name_en              String?                @db.VarChar(100)
  max_users            Int                    @default(5)
  max_products         Int                    @default(500)
  price_monthly        Decimal                @db.Decimal(10, 2)
  price_annual         Decimal?               @db.Decimal(10, 2)
  features             Json                   @default("[]")
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime
  max_branches         Int                    @default(1)
  tenant_subscriptions tenant_subscriptions[]
  tenants              tenants[]
}

model super_admins {
  id            String    @id
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password_hash String
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime
  tenants       tenants[]
}

model tenant_subscriptions {
  id                 String             @id
  tenant_id          String
  plan_id            String
  billing_cycle      String?            @db.VarChar(10)
  amount_paid        Decimal?           @db.Decimal(10, 2)
  currency           String             @default("USD") @db.VarChar(3)
  starts_at          DateTime
  ends_at            DateTime
  payment_ref        String?            @db.VarChar(200)
  notes              String?
  created_at         DateTime           @default(now())
  subscription_plans subscription_plans @relation(fields: [plan_id], references: [id])
  tenants            tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model tenants {
  id                   String                 @id
  name                 String                 @db.VarChar(200)
  slug                 String                 @unique @db.VarChar(100)
  logo_url             String?
  primary_color        String?                @default("#1E40AF") @db.VarChar(7)
  address              String?
  phone                String?                @db.VarChar(50)
  email                String?                @db.VarChar(150)
  website              String?                @db.VarChar(200)
  default_currency     DefaultCurrency        @default(HTG)
  default_language     DefaultLanguage        @default(ht)
  exchange_rate        Decimal                @default(125.00) @db.Decimal(10, 4)
  tax_rate             Decimal                @default(0) @db.Decimal(5, 2)
  plan_id              String?
  status               TenantStatus           @default(pending)
  trial_ends_at        DateTime?
  subscription_ends_at DateTime?
  created_by           String?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  receipt_size         String                 @default("80mm") @db.VarChar(10)
  printer_connection   String                 @default("usb") @db.VarChar(20)
  exchangeRates        String?                @default("{}")
  showExchangeRate     Boolean                @default(false)
  visibleCurrencies    String?                @default("[\"USD\"]")
  show_qr_code         Boolean                @default(true)
  require_quote        Boolean                @default(false)
  allowed_pages        Json?                  @default("{}")
  monthly_price        Int                    @default(0)
  activity_logs        activity_logs[]
  branches             branches[]
  clients              clients[]
  document_sequences   document_sequences[]
  hotel_payments       hotel_payments[]
  hotel_services       hotel_services[]
  invoice_items        invoice_items[]
  invoices             invoices[]
  kane_epay_accounts   kane_epay_accounts[]
  kane_transactions    kane_transactions[]
  notifications        notifications[]
  payments             payments[]
  product_categories   product_categories[]
  products             products[]
  quote_items          quote_items[]
  quotes               quotes[]
  reservations         reservations[]
  room_types           room_types[]
  rooms                rooms[]
  sabotay_plans        sabotay_plans[]
  stock_movements      stock_movements[]
  tenant_subscriptions tenant_subscriptions[]
  super_admins         super_admins?          @relation(fields: [created_by], references: [id])
  subscription_plans   subscription_plans?    @relation(fields: [plan_id], references: [id])
  users                users[]
}

model users {
  id                                    String               @id
  tenant_id                             String
  full_name                             String               @db.VarChar(150)
  email                                 String               @db.VarChar(150)
  password_hash                         String
  phone                                 String?              @db.VarChar(50)
  avatar_url                            String?
  role                                  UserRole             @default(cashier)
  permissions                           Json                 @default("{}")
  preferred_lang                        DefaultLanguage      @default(ht)
  is_active                             Boolean              @default(true)
  last_login_at                         DateTime?
  password_reset_token                  String?
  password_reset_expires                DateTime?
  created_by                            String?
  created_at                            DateTime             @default(now())
  updated_at                            DateTime
  password_changed_at                   DateTime?            @db.Timestamptz(6)
  activity_logs                         activity_logs[]
  branch_users                          branch_users[]
  clients                               clients[]
  hotel_payments                        hotel_payments[]
  hotel_services                        hotel_services[]
  invoices_invoices_cancelled_byTousers invoices[]           @relation("invoices_cancelled_byTousers")
  invoices_invoices_created_byTousers   invoices[]           @relation("invoices_created_byTousers")
  kane_epay_accounts                    kane_epay_accounts[]
  kane_transactions                     kane_transactions[]
  notifications                         notifications[]
  payments                              payments[]
  products                              products[]
  quotes                                quotes[]
  reservations                          reservations[]
  sabotay_members                       sabotay_members[]
  sabotay_payments                      sabotay_payments[]
  sabotay_plans                         sabotay_plans[]
  stock_movements                       stock_movements[]
  tenants                               tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
}

enum DefaultCurrency {
  HTG
  USD
}

enum DefaultLanguage {
  ht
  fr
  en
}

enum InvoiceStatus {
  unpaid
  partial
  paid
  cancelled
  refunded
}

enum KaneTransactionType {
  ouverture
  depot
  retrait
}

enum PaymentMethod {
  cash
  card
  transfer
  moncash
  natcash
  check
  other
}

enum QuoteStatus {
  draft
  sent
  accepted
  converted
  cancelled
  expired
}

enum ReservationStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum RoomStatus {
  available
  occupied
  cleaning
  maintenance
  reserved
}

enum ServiceType {
  food
  drink
  laundry
  transport
  spa
  room_service
  other
}

enum StockMovementType {
  sale
  purchase
  adjustment
  return_item
  loss
  transfer
}

enum TenantStatus {
  pending
  active
  suspended
  cancelled
}

enum UserRole {
  admin
  cashier
  stock_manager
  viewer
}
